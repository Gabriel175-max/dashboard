# ID da propriedade GA4 (apenas o número)
GA4_PROPERTY_ID=533096274

# URL do seu site no Search Console (ex: https://seusite.com.br)
GSC_SITE_URL=https://seusite.com.br

# Caminho para o arquivo JSON da conta de serviço do Google
GOOGLE_SERVICE_ACCOUNT_KEY=./service-account.json

# Token de segurança para o dashboard (pode ser qualquer senha forte)
DASHBOARD_TOKEN=mude-essa-senha-aqui

# Porta do servidor
PORT=3001
